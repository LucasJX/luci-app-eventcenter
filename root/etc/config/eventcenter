config eventcenter 'global'
    option enable '1'
    option log_path '/tmp/eventcenter.log'
    option log_max_lines '1000'
    option dedup_ttl '300'
    option dedup_path '/tmp/eventcenter_dedup'
    option dedup_max '500'
    option aggregate_enable '1'
    option aggregate_ttl '600'

config notifier 'telegram'
    option enable '1'
    option token ''
    option chatid ''
    option parse_mode 'Markdown'

config monitor 'openclash'
    option enable '1'
    option paths ''
    option realtime '1'
    option debounce '5'

config health 'node_health'
    option enable '0'
    option interval '5'
    option delay_threshold '3000'
    option test_url 'http://www.gstatic.com/generate_204'
    option notify_recovery '1'
    option monitor_groups ''

config system_health 'system_health'
    option enable '0'
    option interval '2'
    option cpu_threshold '80'
    option mem_threshold '85'
    option disk_threshold '90'
    option temp_threshold '75'
    option notify_recovery '1'

config device_monitor 'device_monitor'
    option enable '0'
    option interval '1'
    option track_macs ''
    option notify_recovery '1'
