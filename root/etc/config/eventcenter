config eventcenter 'global'
    option enable '1'
    option log_path '/etc/eventcenter/eventcenter.log'
    option log_max_lines '1000'
    option dedup_ttl '300'
    option dedup_path '/tmp/eventcenter_dedup'
    option dedup_max '500'
    option aggregate_enable '0'

config notifier 'telegram'
    option enable '0'
    option token ''
    option chatid ''
    option parse_mode 'Markdown'

config notifier 'wechat'
    option enable '0'
    option webhook ''
    option mention ''

config notifier 'bark'
    option enable '0'
    option server 'https://api.day.app'
    option device_key ''
    option sound 'minuet'
    option group 'EventCenter'

config notifier 'serverchan'
    option enable '0'
    option sendkey ''

config notifier 'serverchan3'
    option enable '0'
    option sendkey ''
    option uid ''

config notifier 'ntfy'
    option enable '0'
    option url 'https://ntfy.sh'
    option topic ''
    option token ''
    option user ''
    option pass ''
    option priority 'default'
    option tags ''
    option icon ''
    option click ''

config notifier 'pushplus'
    option enable '0'
    option token ''
    option topic ''
    option template 'markdown'

config monitor 'openclash'
    option enable '1'
    option interval '5'
    option paths ''
    option realtime '1'
    option debounce '5'

config health 'health'
    option enable '0'
    option interval '5'
    option delay_threshold '3000'
    option test_url 'http://www.gstatic.com/generate_204'
    option notify_recovery '1'
    option monitor_groups ''
    option state_file '/etc/eventcenter/node_state'

config monitor 'sub'
    option enable '0'
    option check_interval '6'
    option remind_days '7'

config system_health 'system_health'
    option enable '0'
    option interval '5'

config device_monitor 'device_monitor'
    option enable '0'
    option interval '2'
